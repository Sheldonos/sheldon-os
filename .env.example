# Sheldon OS Environment Configuration
# Copy this file to .env and fill in your values

# Environment
ENVIRONMENT=development
DEBUG=true

# System
SYSTEM_NAME=Sheldon OS
VERSION=0.1.0

# Database Configuration
DATABASE__HOST=localhost
DATABASE__PORT=5432
DATABASE__NAME=sheldon_os
DATABASE__USER=sheldon
DATABASE__PASSWORD=your_secure_password_here
DATABASE__POOL_SIZE=10
DATABASE__MAX_OVERFLOW=20

# Redis Configuration
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__DB=0
REDIS__PASSWORD=
REDIS__MAX_CONNECTIONS=50

# LLM Configuration
LLM__PROVIDER=anthropic
LLM__MODEL=claude-3-5-sonnet-20241022
LLM__API_KEY=your_anthropic_api_key_here
LLM__TEMPERATURE=0.7
LLM__MAX_TOKENS=4096
LLM__TIMEOUT=60

# Alternative LLM Providers
# OPENAI_API_KEY=your_openai_api_key_here

# Agent Configuration
AGENT__MAX_CONCURRENT_AGENTS=100
AGENT__AGENT_TIMEOUT=300
AGENT__RETRY_ATTEMPTS=3
AGENT__HEALTH_CHECK_INTERVAL=60
AGENT__CONTEXT_WINDOW_SIZE=10000

# Memory Configuration
MEMORY__SHORT_TERM_CAPACITY=1000
MEMORY__LONG_TERM_CAPACITY=100000
MEMORY__CONSOLIDATION_INTERVAL=3600
MEMORY__RETENTION_DAYS=90
MEMORY__EMBEDDING_MODEL=text-embedding-3-small
MEMORY__VECTOR_BACKEND=zeroentropy
MEMORY__RERANKER_ENABLED=true
MEMORY__RERANKER_MODEL=zeroentropy-reranker
MEMORY__GRAPH_BACKEND=neo4j
MEMORY__GRAPH_EXPANSION_HOPS=2
MEMORY__SYNTHESIS_ENABLED=true
MEMORY__GAP_ANALYSIS_ENABLED=true

# Security Configuration
SECURITY__SECRET_KEY=your_secret_key_here_change_in_production
SECURITY__JWT_ALGORITHM=HS256
SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=30
SECURITY__REFRESH_TOKEN_EXPIRE_DAYS=7
SECURITY__ALLOWED_ORIGINS=*

# Monitoring Configuration
MONITORING__LOG_LEVEL=INFO
MONITORING__LOG_FORMAT=json
MONITORING__METRICS_ENABLED=true
MONITORING__TRACING_ENABLED=true
MONITORING__SENTRY_DSN=

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Paths
BASE_PATH=.